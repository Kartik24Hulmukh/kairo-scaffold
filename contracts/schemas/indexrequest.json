{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "IndexRequest",
  "type": "object",
  "properties": {
    "doc_id": {
      "type": "string"
    },
    "source_path": {
      "type": "string"
    },
    "pages": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "width_px": { "type": "number" },
          "height_px": { "type": "number" }
        },
        "required": ["width_px", "height_px"]
      }
    },
    "chunks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "text": { "type": "string" },
          "bbox": {
            "type": "object",
            "properties": {
              "x0": { "type": "number" },
              "y0": { "type": "number" },
              "x1": { "type": "number" },
              "y1": { "type": "number" }
            },
            "required": ["x0", "y0", "x1", "y1"]
          },
          "page_index": { "type": "integer" }
        },
        "required": ["id", "text", "bbox", "page_index"]
      }
    }
  },
  "required": ["doc_id", "source_path", "pages", "chunks"]
}
