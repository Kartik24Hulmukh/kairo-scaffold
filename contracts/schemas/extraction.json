{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Extraction",
  "type": "object",
  "properties": {
    "id": {
      "type": "string"
    },
    "doc_id": {
      "type": "string"
    },
    "field": {
      "type": "string"
    },
    "value": {
      "type": ["string", "null"]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "status": {
      "type": "string",
      "enum": ["suggested", "accepted", "edited", "rejected", "blocked", "pending_review", "grounded"]
    },
    "method": {
      "type": "string",
      "enum": ["exact", "fuzzy", "semantic", "visual", "block"]
    },
    "anchors": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "chunk_id": { "type": "string" },
          "page": { "type": "integer" },
          "bbox": {
            "type": "object",
            "properties": {
              "x0": { "type": "number" },
              "y0": { "type": "number" },
              "x1": { "type": "number" },
              "y1": { "type": "number" }
            },
            "required": ["x0", "y0", "x1", "y1"]
          },
          "char_start": { "type": "integer" },
          "char_end": { "type": "integer" }
        },
        "required": ["chunk_id", "page", "bbox", "char_start", "char_end"]
      }
    }
  },
  "required": ["id", "doc_id", "field", "value", "confidence", "status", "method", "anchors"]
}
