# =============================================================================
# Kairo Scaffold — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Local Kairo runtime state (NEVER commit — contains local DB, secrets, images)
# -----------------------------------------------------------------------------
.kairo/
.kairo_test/
*.db
*.db-journal
*.db-wal
*.db-shm

# -----------------------------------------------------------------------------
# Rust build artifacts
# -----------------------------------------------------------------------------
/target/
**/target/
cargo-out-tmp/
build/

# -----------------------------------------------------------------------------
# Python virtual environments
# -----------------------------------------------------------------------------
.venv/
venv/
ENV/
env/
kernel/sidecar/.venv/

# -----------------------------------------------------------------------------
# Python cache & compiled files
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.pyc
*.egg
*.egg-info/
dist/
*.whl
pip-wheel-metadata/

# -----------------------------------------------------------------------------
# Coverage & test artifacts
# -----------------------------------------------------------------------------
.coverage
.coverage.*
coverage.xml
htmlcov/
.pytest_cache/
.hypothesis/
*.log
pytest.ini.log

# -----------------------------------------------------------------------------
# Node / JS build artifacts
# -----------------------------------------------------------------------------
node_modules/
dist/
.next/
.nuxt/
*.min.js
*.min.css

# -----------------------------------------------------------------------------
# Secrets & credentials (hard stops)
# -----------------------------------------------------------------------------
*.pem
*.key
*.crt
*.env
.env.*
!.env.example
secrets.json
credentials.json

# -----------------------------------------------------------------------------
# OS-generated files
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V10
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# Editor / IDE files
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.bak

# -----------------------------------------------------------------------------
# Cargo lock (keep for library crates; keep Cargo.lock for binaries)
# Cargo.lock is intentionally NOT ignored — it's a binary/application crate
# -----------------------------------------------------------------------------
# Cargo.lock  <-- DO NOT uncomment: we want reproducible builds

# -----------------------------------------------------------------------------
# Generated benchmark outputs (regenerated by make bench)
# -----------------------------------------------------------------------------
bench/history.jsonl
bench/REPORT.md
bench/leaderboard.html

# -----------------------------------------------------------------------------
# Scratch / local working files
# -----------------------------------------------------------------------------
scratch/
*.tmp
*.temp
progress.md
mantishack-report.json
omo-report.json
inspect_schema.py
derived_ground_truth.json
1000x-stress-readiness-report.md
TEST_READY.md

# -----------------------------------------------------------------------------
# AI agent working files (Antigravity / Claude Code runtime state)
# -----------------------------------------------------------------------------
.agents/
.agent/

# -----------------------------------------------------------------------------
# Overlay build output
# -----------------------------------------------------------------------------
overlay/dist/
overlay/node_modules/

# -----------------------------------------------------------------------------
# Large binary / generated assets (keep demo.gif — it's the Show HN asset)
# -----------------------------------------------------------------------------
*.onnx
*.gguf
*.bin
*.safetensors

# -----------------------------------------------------------------------------
# Qdrant embedded DB lock files
# -----------------------------------------------------------------------------
.kairo/qdrant/.lock
.kairo/qdrant/lock.db
kernel/sidecar/.kairo/qdrant/.lock
kernel/sidecar/.kairo/qdrant/lock.db
