{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "kairo-overlay",
  "version": "0.1.0",
  "identifier": "com.kairo.overlay",
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [],
    "externalBin": [
      "sidecar/kairo-sidecar"
    ],
    "macOS": {
      "entitlements": "entitlements.plist",
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": null,
      "minimumSystemVersion": "12.0"
    }
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Kairo Overlay",
        "width": 800,
        "height": 600,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "shadow": false,
        "focus": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "plugins": {
    "global-shortcut": {}
  }
}
