  "title": "Paper Pack Schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "authors": {
      "type": "string"
    },
    "abstract_summary": {
      "type": "string"
    },
    "key_claims": {
      "type": "string"
    },
