{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Contract Pack Schema",
  "type": "object",
  "properties": {
    "parties": {
      "type": "string"
    },
    "effective_date": {
      "type": "string"
    },
    "termination_date": {
      "type": "string"
    },
    "obligations": {
      "type": "string"
    },
    "governing_law": {
      "type": "string"
    },
    "payment_terms": {
      "type": "string"
    },
    "confidentiality_clause": {
      "type": "string"
    }
  },
  "required": ["parties", "governing_law"]
}
